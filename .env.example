# ── Notes Module ──────────────────────────────────────────────────────────────
# Copy to .env and fill in all values before running.

# Port this module's nginx container exposes on the host.
# Third-party modules: pick any free port in the 4000-4999 range.
FPNOTES_UI_PORT=4001

# Port the Python API container exposes on the host.
FPNOTES_API_PORT=4002

# Database credentials for the notes PostgreSQL instance.
FPNOTES_DB_PASSWORD=changeme

# The provisioning secret — must match PROVISIONING_SECRET in deploy/.env.
PROVISIONING_SECRET=changeme

# Authentik JWKS endpoint. Must match the value in your main stack .env.
JWKS_URL=https://auth.yourdomain.com/application/o/fuzzypeanut/jwks/

# The URL the browser uses to reach the notes API.
# In production, point this at your nginx reverse proxy entry.
VITE_NOTES_API_URL=http://localhost:4002
